<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tencent.wxcloudrun.dao.GroupBuyMapper">

    <resultMap id="groupBuyMapper" type="com.tencent.wxcloudrun.model.GroupBuy">
        <id property="id" column="id"/>
        <result property="inputType" column="input_type"/>
        <result property="rawText" column="raw_text"/>
        <result property="platform" column="platform"/>
        <result property="productName" column="product_name"/>
        <result property="productDesc" column="product_desc"/>
        <result property="groupPrice" column="group_price"/>
        <result property="remainingSlots" column="remaining_slots"/>
        <result property="shareCode" column="share_code"/>
        <result property="imageUrl" column="image_url"/>
        <result property="shareUrl" column="share_url"/>
        <result property="initiatorId" column="initiator_id"/>
        <result property="expireTime" column="expire_time" javaType="java.time.LocalDateTime"/>
        <result property="createdAt" column="created_at" javaType="java.time.LocalDateTime"/>
    </resultMap>

    <resultMap id="wechatQrTaskMapper" type="com.tencent.wxcloudrun.model.WechatQrTask">
        <id property="id" column="id"/>
        <result property="groupBuyId" column="group_buy_id"/>
        <result property="qrUrl" column="qr_url"/>
        <result property="initiatorId" column="initiator_id"/>
        <result property="qrStatus" column="qr_status"/>
        <result property="qrAttempts" column="qr_attempts"/>
        <result property="qrError" column="qr_error"/>
        <result property="qrRawText" column="qr_raw_text"/>
        <result property="sameProduct" column="same_product"/>
        <result property="matchedGroupBuyId" column="matched_group_buy_id"/>
    </resultMap>

    <insert id="insert" parameterType="com.tencent.wxcloudrun.model.GroupBuy" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO group_buy (`input_type`, `raw_text`, `platform`, `product_name`, `product_desc`, `group_price`,
                               `remaining_slots`, `share_code`, `image_url`, `share_url`,
                               `initiator_id`, `expire_time`, `created_at`)
        VALUES (#{inputType}, #{rawText}, #{platform}, #{productName}, #{productDesc}, #{groupPrice},
                #{remainingSlots}, #{shareCode}, #{imageUrl}, #{shareUrl},
                #{initiatorId}, #{expireTime}, #{createdAt})
    </insert>

    <insert id="insertWechatQrTask" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wechat_qr_task (`qr_url`, `initiator_id`, `qr_status`, `qr_attempts`)
        VALUES (#{qrUrl}, #{initiatorId}, 'PENDING', 0)
    </insert>

    <select id="selectWechatQrTaskById" resultMap="wechatQrTaskMapper">
        SELECT * FROM wechat_qr_task WHERE id = #{id}
    </select>

    <select id="selectWechatQrTaskByUrl" resultMap="wechatQrTaskMapper">
        SELECT * FROM wechat_qr_task WHERE qr_url = #{qrUrl} ORDER BY id DESC LIMIT 1
    </select>

    <update id="bindWechatQrTaskGroupBuy">
        UPDATE wechat_qr_task
        SET group_buy_id = #{groupBuyId},
            same_product = 0,
            matched_group_buy_id = NULL,
            qr_status = 'SUCCESS',
            updated_at = NOW()
        WHERE id = #{taskId}
    </update>

    <select id="selectById" resultMap="groupBuyMapper">
        SELECT * FROM group_buy WHERE id = #{id}
    </select>

    <select id="selectByQrTaskId" resultMap="groupBuyMapper">
        SELECT gb.* FROM group_buy gb
        INNER JOIN wechat_qr_task task ON task.group_buy_id = gb.id
        WHERE task.id = #{taskId}
        LIMIT 1
    </select>

    <select id="selectMatchedByQrTaskId" resultMap="groupBuyMapper">
        SELECT gb.* FROM group_buy gb
        INNER JOIN wechat_qr_task task ON task.matched_group_buy_id = gb.id
        WHERE task.id = #{taskId}
        LIMIT 1
    </select>

    <select id="selectByInitiator" resultMap="groupBuyMapper">
        SELECT * FROM group_buy
        WHERE initiator_id = #{initiatorId}
        <if test="status != null and status == 1">
            AND expire_time &gt; NOW()
        </if>
        <if test="status != null and status == 2">
            AND expire_time &lt;= NOW()
        </if>
        <if test="keyword != null and keyword != ''">
            AND share_url LIKE CONCAT('%', #{keyword}, '%')
        </if>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="selectActive" resultMap="groupBuyMapper">
        SELECT * FROM group_buy
        WHERE 1=1
        <if test="hideExpired == null or hideExpired">
            AND expire_time &gt; NOW()
        </if>
        <if test="keywords != null and keywords.size() > 0">
            AND (
            <foreach collection="keywords" item="kw" separator=" OR ">
                share_url LIKE CONCAT('%', #{kw}, '%')
            </foreach>
            )
        </if>
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countActive" resultType="int">
        SELECT COUNT(*) FROM group_buy
        WHERE 1=1
        <if test="hideExpired == null or hideExpired">
            AND expire_time &gt; NOW()
        </if>
        <if test="keywords != null and keywords.size() > 0">
            AND (
            <foreach collection="keywords" item="kw" separator=" OR ">
                share_url LIKE CONCAT('%', #{kw}, '%')
            </foreach>
            )
        </if>
    </select>

    <select id="selectActiveByShareCodeOrUrl" resultMap="groupBuyMapper">
        SELECT * FROM group_buy
        WHERE (
            <if test="shareCode != null and shareCode != ''">
                share_code = #{shareCode}
            </if>
            <if test="shareCode != null and shareCode != '' and shareUrl != null and shareUrl != ''">
                OR
            </if>
            <if test="shareUrl != null and shareUrl != ''">
                share_url = #{shareUrl}
            </if>
        )
        LIMIT 1
    </select>

    <select id="selectActiveByProductDesc" resultMap="groupBuyMapper">
        SELECT * FROM group_buy
        WHERE expire_time &gt; NOW()
        AND
            product_desc = #{productDesc}
        LIMIT 1
    </select>

</mapper>
